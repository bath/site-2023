---
import NameWithSun from "./NameWithSun.astro";
import { profile } from "../data/profile";

const { pathname } = Astro.props;

const isActive = (path: string) => {
  if (path === "/") {
    return pathname === "/";
  }
  return pathname.startsWith(path);
};
---

<nav class="fixed-nav">
  <NameWithSun />
  <div class="subheading">
    <div>{profile.tagline}</div>
  </div>
  <div class="nav-links">
    <a
      href="/"
      class:list={["nav-link", { active: isActive("/") }]}
      aria-current={isActive("/") ? "page" : undefined}
    >
      About
    </a>
    <a href="/work" class:list={["nav-link", { active: isActive("/work") }]}>
      Work
    </a>
    <a
      href="/skills"
      class:list={["nav-link", { active: isActive("/skills") }]}
    >
      Skills
    </a>
    <a class="nav-link external" href={profile.resumeHref}>Resume ↗</a>
    <a class="nav-link external" href={profile.linkedin}>LinkedIn ↗</a>
    <a class="nav-link external" href={profile.github}>GitHub ↗</a>
    <a class="nav-link external" href={`mailto:${profile.email}`}>Email ↗</a>
  </div>
</nav>

<style>
  /* Layout + responsive behavior for .fixed-nav / .nav-links / .subheading
     lives in global.css so it can coordinate with .content and win on mobile
     (scoped styles out-specify global, so keep them out of here). */
  .external {
    font-size: 0.85em;
    color: var(--text-subtle);
  }

  .external:first-of-type {
    margin-top: 1em;
  }

  @media (max-width: 820px) {
    /* horizontal nav row — drop the desktop spacer above the first link */
    .external:first-of-type {
      margin-top: 0;
    }
  }
</style>
