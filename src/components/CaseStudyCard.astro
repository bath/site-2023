---
// The signature element: a "results brief" card. Left rail is a metric readout
// (big tabular number + tracked label), right side is the narrative — pillar
// tag, title, and a problem → approach → outcome line. Metrics are the spine,
// so they get the visual weight; the prose supports them.

interface Metric {
  value: string;
  label: string;
}

interface Props {
  // "backend" | "ai-tooling" — which surface area this evidence proves.
  pillar: "backend" | "ai-tooling";
  pillarLabel: string;
  title: string;
  metrics: Metric[];
  stack?: string;
  // Short narrative: what the situation was and what shipped.
  body: string;
}

const { pillar, pillarLabel, title, metrics, stack, body } = Astro.props;
---

<article class="cs-card" data-pillar={pillar}>
  <div class="cs-card-rail">
    {
      metrics.map((m) => (
        <div class="cs-metric">
          <span class="cs-metric-value">{m.value}</span>
          <span class="cs-metric-label">{m.label}</span>
        </div>
      ))
    }
  </div>

  <div class="cs-card-body">
    <span class="cs-pillar-tag">{pillarLabel}</span>
    <h3 class="cs-card-title">{title}</h3>
    <p class="cs-card-text">{body}</p>
    {stack && <p class="cs-card-stack">{stack}</p>}
  </div>
</article>

<style>
  .cs-card {
    display: grid;
    grid-template-columns: minmax(0, 13rem) minmax(0, 1fr);
    gap: 1.75rem;
    padding: 1.6rem;
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    background: var(--surface);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .cs-card:hover {
    border-color: var(--accent-tint-border);
    transform: translateY(-2px);
  }

  /* --- Metric rail ----------------------------------------------------- */
  .cs-card-rail {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding-right: 1.5rem;
    border-right: 1px solid var(--border);
  }

  .cs-metric {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .cs-metric-value {
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  /* First metric reads as the headline outcome — accent it. */
  .cs-metric:first-child .cs-metric-value {
    color: var(--accent-strong);
  }

  .cs-metric-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-subtle);
    line-height: 1.35;
  }

  /* --- Narrative ------------------------------------------------------- */
  .cs-card-body {
    min-width: 0;
  }

  .cs-pillar-tag {
    display: inline-block;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-strong);
    padding: 0.22rem 0.5rem;
    border: 1px solid var(--accent-tint-border);
    background: var(--accent-tint);
    border-radius: 5px;
  }

  .cs-card-title {
    margin: 0.85rem 0 0.55rem;
    font-size: 1.22rem;
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .cs-card-text {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.62;
    color: var(--text-muted);
  }

  .cs-card-stack {
    margin: 0.9rem 0 0;
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }

  /* --- Mobile: rail stacks above narrative, becomes a metric row ------- */
  @media (max-width: 640px) {
    .cs-card {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      padding: 1.35rem;
    }

    .cs-card-rail {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem 1.75rem;
      padding-right: 0;
      padding-bottom: 1.25rem;
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .cs-metric-value {
      font-size: 1.5rem;
    }
  }
</style>
