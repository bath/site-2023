---
import { profile } from "../data/profile";
// Sun position and name shadow are populated live by LiveClock on the
// client. SSR renders neutral defaults (sun hidden, no shadow) so the
// initial paint never leaks a stale build-time value.
---

<div class="name-container">
  <div class="sun-wrapper" aria-hidden="true">
    <div class="sun" data-live="sun" style="opacity: 0"></div>
  </div>
  <a
    class="name"
    href="/"
    aria-label="Home"
    data-live="name-shadow"
  >
    {profile.name}
  </a>
</div>

<style>
  .name-container {
    position: relative;
    display: inline-block;
  }

  .sun-wrapper {
    position: absolute;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .sun {
    position: absolute;
    width: 16px;
    height: 16px;
    background: #ff7b4d;
    border-radius: 50%;
    box-shadow: 0 0 20px rgba(255, 90, 60, 0.7);
    left: 50%;
    top: 50%;
    will-change: transform, opacity;
    transition:
      transform 1.2s ease-out,
      opacity 1.2s ease-out;
  }

  .name {
    font-size: 2em;
    position: relative;
    z-index: 1;
    will-change: text-shadow;
    transition:
      text-shadow 1.2s ease-out,
      color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .name:hover {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 820px) {
    .name {
      font-size: 1.7em;
    }

    .name:hover {
      transform: none;
    }
  }

  .sun::after {
    content: "";
    position: absolute;
    inset: -4px;
    background: radial-gradient(
      circle,
      rgba(255, 123, 77, 0.4),
      transparent 70%
    );
    border-radius: 50%;
    animation: glow 3s infinite;
  }

  @keyframes glow {
    0%,
    100% {
      box-shadow: 0 0 20px rgba(255, 90, 60, 0.7);
    }
    50% {
      box-shadow: 0 0 30px rgba(255, 90, 60, 0.9);
    }
  }
</style>
