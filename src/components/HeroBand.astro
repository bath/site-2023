---
// The signature of the Hero direction: a warm band over the seasonal gradient
// carrying the in-variant nav, a live local-clock readout, the big name (with
// the sun + tracking shadow from the live clock), and — on the home page — the
// hook. `size="slim"` drops the hook and shrinks type for the inner pages.
import HeroNav from "./HeroNav.astro";
import { profile } from "../data/profile";

interface Props {
  size?: "full" | "slim";
  page?: "" | "work" | "skills";
}

const { size = "full", page = "" } = Astro.props;
---

<header class:list={["hero-band", size]}>
  <HeroNav page={page} />

  <div class="hero-inner">
    <p class="hero-readout" aria-label="Local time and day">
      <span class="ro-greet">
        <span data-live="greeting-emoji">👋🏻</span>
        <span data-live="greeting-text">Hello</span>
      </span>
      <span class="ro-sep" aria-hidden="true">·</span>
      <span class="ro-item">Day <span data-live="day">—</span></span>
      <span class="ro-sep" aria-hidden="true">·</span>
      <span class="ro-item"><span data-live="time">—:—</span></span>
      <span class="ro-item ro-tz"><span data-live="tz">your time</span></span>
    </p>

    <div class="hero-name-wrap">
      <span class="hero-sun" data-live="sun" style="opacity: 0" aria-hidden="true"></span>
      <h1 class="hero-name" data-live="name-shadow">{profile.name}</h1>
    </div>

    <p class="hero-title">{profile.title} · {profile.locationShort}</p>

    {size === "full" && <p class="hero-hook">{profile.hook}</p>}
  </div>
</header>

<style>
  .hero-band {
    position: relative;
    /* Translucent warm panel so the seasonal gradient reads through while the
       text stays legible in both themes. */
    background: var(--overlay);
    border: 1px solid var(--glass-border);
    border-radius: 22px;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    padding: 1.4rem 2rem 2.6rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  /* A faint warm wash bleeding up from the bottom, echoing the accent without
     fighting the gradient behind the panel. */
  .hero-band::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 35%,
      var(--accent-tint) 140%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    margin-top: 2.2rem;
  }

  .hero-band.slim {
    padding: 1.4rem 2rem 1.8rem;
  }

  .hero-band.slim .hero-inner {
    margin-top: 1.4rem;
  }

  /* ---- live readout ---- */
  .hero-readout {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    margin: 0 0 0.9rem;
    font-size: 0.86rem;
    letter-spacing: 0.02em;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
  }

  .ro-greet {
    color: var(--text-muted);
    font-weight: 500;
  }

  .ro-sep {
    color: var(--text-faint);
  }

  .ro-tz {
    color: var(--text-faint);
  }

  /* ---- name + sun ---- */
  .hero-name-wrap {
    position: relative;
    display: inline-block;
  }

  .hero-sun {
    position: absolute;
    left: 50%;
    top: 0.55em;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent-strong);
    box-shadow: 0 0 18px rgba(255, 90, 60, 0.65);
    pointer-events: none;
    will-change: transform, opacity;
    transition:
      transform 1.2s ease-out,
      opacity 1.2s ease-out;
  }

  .hero-name {
    /* Display serif, set directly to beat the universal `*` font rule. */
    font-family: "Iowan Old Style", Georgia, "Times New Roman", ui-serif, serif;
    font-size: clamp(2.6rem, 8vw, 4.6rem);
    line-height: 1.02;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--text);
    will-change: text-shadow;
    transition: text-shadow 1.2s ease-out;
  }

  .hero-band.slim .hero-name {
    font-size: clamp(2rem, 6vw, 3.1rem);
  }

  .hero-title {
    margin: 0.7rem 0 0;
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-strong);
    font-weight: 600;
  }

  .hero-hook {
    margin: 1.3rem 0 0;
    max-width: 34ch;
    font-size: clamp(1.15rem, 2.6vw, 1.55rem);
    line-height: 1.4;
    color: var(--text);
    text-wrap: balance;
  }

  @media (max-width: 480px) {
    .hero-band {
      padding: 1.1rem 1.25rem 2rem;
      border-radius: 18px;
    }
    .hero-band.slim {
      padding: 1.1rem 1.25rem 1.4rem;
    }
    .hero-inner {
      margin-top: 1.6rem;
    }
    .hero-sun {
      top: 0.4em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sun,
    .hero-name {
      transition: none;
    }
  }
</style>
