---
import { profile } from "../data/profile";

interface Props {
  // Which page is current, for aria-current + active styling.
  page?: "" | "work" | "skills";
}

const { page = "" } = Astro.props;

const links = [
  { href: "/casestudy", label: "Overview", key: "" },
  { href: "/casestudy/work", label: "Experience", key: "work" },
  { href: "/casestudy/skills", label: "Skills", key: "skills" },
] as const;
---

<header class="cs-nav">
  <a class="cs-wordmark" href="/casestudy">
    <span class="cs-name">{profile.name}</span>
    <span class="cs-loc">{profile.locationShort}</span>
  </a>
  <nav class="cs-links" aria-label="Primary">
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={["cs-link", { active: l.key === page }]}
          aria-current={l.key === page ? "page" : undefined}
        >
          {l.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .cs-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.6rem 0 1.4rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .cs-wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    color: var(--text);
  }

  .cs-name {
    font-size: 1.02rem;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .cs-loc {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding: 0.18rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .cs-links {
    display: flex;
    gap: 0.4rem;
  }

  .cs-link {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
    transition:
      color 0.18s ease,
      background 0.18s ease;
  }

  .cs-link:hover {
    color: var(--text);
    background: var(--surface);
  }

  .cs-link.active {
    color: var(--text);
    background: var(--accent-tint);
    box-shadow: inset 0 0 0 1px var(--accent-tint-border);
  }

  @media (max-width: 480px) {
    .cs-nav {
      gap: 0.75rem;
    }
    .cs-links {
      gap: 0.25rem;
    }
    .cs-link {
      padding: 0.35rem 0.55rem;
    }
  }
</style>
