---
import type { WeatherData } from "../types";
import { profile } from "../data/profile";

interface Props {
  weatherData: WeatherData | null;
}

const { weatherData } = Astro.props;
---

<div class="info-container">
  <div class="location">{profile.locationShort}</div>
  <div class="day-counter">
    Day <span data-live="day">—</span>
    <div class="time-display">
      <span data-live="time">—:—</span>
      <span class="tz-label" data-live="tz"></span>
    </div>
  </div>
  {
    weatherData === null ? (
      <div class="weather-info weather-author">Kansas City weather unavailable</div>
    ) : (
      <div class="weather-info weather-author">
        Kansas City · {weatherData.temperature}°F · {weatherData.description}
      </div>
    )
  }
</div>

<style>
  .info-container {
    position: fixed;
    bottom: 20px;
    left: 20px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    z-index: 1000;
    font-size: 14px;
    color: rgba(35, 31, 32, 0.6);
  }

  .location {
    font-size: 14px;
    color: rgba(35, 31, 32, 0.6);
    padding: 5px 10px;
  }

  .day-counter,
  .weather-info {
    padding: 5px 10px;
    border-radius: 4px;
  }

  .time-display {
    font-size: 12px;
    margin-top: 2px;
    opacity: 0.8;
  }

  .tz-label {
    margin-left: 0.4em;
    font-size: 11px;
    opacity: 0.7;
  }

  .weather-author {
    font-size: 12px;
    opacity: 0.85;
  }
</style>
