---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { profile } from "../data/profile";

import GradientBackground from "../components/GradientBackground.astro";
import ThemeScript from "../components/ThemeScript.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import VariantSwitcher from "../components/VariantSwitcher.astro";

interface Props {
  title?: string;
  description?: string;
  // Identifies which design direction this page belongs to. Omit on the index
  // hub (no switcher highlight, switcher still shown for navigation).
  variant?: "editorial" | "sidebar" | "hero" | "casestudy";
  page?: "" | "work" | "skills";
  showSwitcher?: boolean;
}

const {
  title,
  description,
  variant,
  page = "",
  showSwitcher = true,
} = Astro.props;

const pageTitle = title ?? `${profile.name} — ${profile.title} · SF`;
const pageDescription = description ?? profile.hook;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#e8f0fa"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#0f1218"
    />
    <ClientRouter />
  </head>
  <body>
    <GradientBackground />
    <ThemeToggle />
    <slot />
    {
      showSwitcher && variant && (
        <VariantSwitcher current={variant} page={page} />
      )
    }
  </body>
</html>

<style is:global>
  /* Keep the floating switcher from colliding with content at the bottom of
     any variant. Each variant can still set its own padding; this is a floor. */
  body {
    padding-bottom: 4.5rem;
  }
</style>
