---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { fetchWeatherData } from "../utils/weatherUtils";
import { profile } from "../data/profile";
import type { WeatherData } from "../types";

import Navigation from "../components/Navigation.astro";
import InfoContainer from "../components/InfoContainer.astro";
import GradientBackground from "../components/GradientBackground.astro";
import EasterEggs from "../components/EasterEggs.astro";
import LiveClock from "../components/LiveClock.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";

const pathname = Astro.url.pathname;

// Only the weather fetch stays on the server — it needs the API key.
// Time, day-of-year, sun angle, and greeting all update client-side in
// the visitor's own timezone (see src/components/LiveClock.astro).
const weatherData: WeatherData | null = import.meta.env.WEATHER_API_KEY
  ? await fetchWeatherData(import.meta.env.WEATHER_API_KEY)
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`${profile.name} — ${profile.title} in ${profile.location}`}
    />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>mzb.dev</title>
    <ClientRouter />
    <SpeedInsights />
    <Analytics />
  </head>
  <body>
    <GradientBackground />
    <div class="layout-container">
      <Navigation pathname={pathname} />
      <main class="content">
        <slot />
      </main>
    </div>
    <InfoContainer weatherData={weatherData} />
    <EasterEggs />
    <LiveClock />
  </body>
</html>

<style is:global>
  /* Fallback color shown for the split second before GradientBackground
     mounts. Matches the lightest seasonal start so the transition is
     imperceptible. */
  html {
    background-color: rgb(232, 240, 250);
  }
</style>
