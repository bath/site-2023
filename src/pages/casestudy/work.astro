---
import VariantBase from "../../layouts/VariantBase.astro";
import CaseStudyNav from "../../components/CaseStudyNav.astro";
import {
  experience,
  earlier,
  leadership,
  education,
} from "../../data/experience";
import { profile } from "../../data/profile";
---

<VariantBase
  title={`Experience — ${profile.name}`}
  description={`The full timeline behind the case studies — ${profile.name}'s roles, projects, and outcomes.`}
  variant="casestudy"
  page="work"
>
  <main class="cs">
    <CaseStudyNav page="work" />

    <div class="cs-content">
      <header class="cs-page-head">
        <h1 class="cs-page-title">Experience</h1>
        <p class="cs-page-sub">
          The full record behind the case studies — roles, the systems shipped,
          and what they moved.
        </p>
      </header>

      <!-- Primary roles as a timeline of case cards. -->
      <section class="cs-timeline" aria-label="Roles">
        {
          experience.map((role) => (
            <article class="cs-role">
              <div class="cs-role-meta">
                <span class="cs-role-dates">{role.dates}</span>
                <span class="cs-role-company">{role.company}</span>
              </div>
              <div class="cs-role-body">
                <h2 class="cs-role-title">{role.title}</h2>
                {role.context && (
                  <p class="cs-role-context">{role.context}</p>
                )}
                <ul class="cs-role-bullets">
                  {role.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </section>

      <!-- Earlier roles — compact, lower weight. -->
      <section class="cs-block" aria-labelledby="cs-earlier-heading">
        <h2 id="cs-earlier-heading" class="cs-block-title">Earlier</h2>
        <ul class="cs-earlier">
          {
            earlier.map((r) => (
              <li class="cs-earlier-item">
                <div class="cs-earlier-head">
                  <span class="cs-earlier-co">{r.company}</span>
                  <span class="cs-earlier-role">{r.title}</span>
                  <span class="cs-earlier-dates">{r.dates}</span>
                </div>
                <p class="cs-earlier-note">{r.note}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Leadership + education, side by side on desktop. -->
      <div class="cs-two-up">
        <section class="cs-block" aria-labelledby="cs-lead-heading">
          <h2 id="cs-lead-heading" class="cs-block-title">Leadership</h2>
          <ul class="cs-plain-list">
            {leadership.map((l) => <li>{l}</li>)}
          </ul>
        </section>

        <section class="cs-block" aria-labelledby="cs-edu-heading">
          <h2 id="cs-edu-heading" class="cs-block-title">Education</h2>
          <ul class="cs-plain-list">
            {
              education.map((e) => (
                <li>
                  <span class="cs-edu-degree">{e.degree}</span>
                  <span class="cs-edu-meta">
                    {e.school} · {e.dates}
                  </span>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>
  </main>
</VariantBase>

<style>
  .cs {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .cs-content {
    padding-top: 2.6rem;
  }

  /* --- Page head -------------------------------------------------------- */
  .cs-page-head {
    margin-bottom: 2.8rem;
  }

  .cs-page-title {
    margin: 0 0 0.6rem;
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    font-weight: 680;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .cs-page-sub {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 60ch;
  }

  /* --- Timeline of roles ------------------------------------------------ */
  .cs-timeline {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
  }

  .cs-role {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    gap: 2rem;
  }

  .cs-role-meta {
    position: relative;
    padding-left: 1.1rem;
    border-left: 2px solid var(--accent-tint-border);
  }

  /* Timeline node on the rail. */
  .cs-role-meta::before {
    content: "";
    position: absolute;
    left: -5px;
    top: 0.35rem;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent-strong);
  }

  .cs-role-dates {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
  }

  .cs-role-company {
    display: block;
    margin-top: 0.3rem;
    font-size: 1.02rem;
    font-weight: 650;
    color: var(--text);
  }

  .cs-role-title {
    margin: 0 0 0.35rem;
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .cs-role-context {
    margin: 0 0 1.1rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-subtle);
  }

  .cs-role-bullets {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .cs-role-bullets li {
    position: relative;
    padding-left: 1.2rem;
    font-size: 0.97rem;
    line-height: 1.62;
    color: var(--text-muted);
  }

  .cs-role-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--accent-tint-border);
  }

  /* --- Blocks (earlier / leadership / education) ------------------------ */
  .cs-block {
    margin-top: 3.4rem;
  }

  .cs-block-title {
    margin: 0 0 1.3rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--border);
  }

  .cs-earlier {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .cs-earlier-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .cs-earlier-co {
    font-size: 1rem;
    font-weight: 650;
    color: var(--text);
  }

  .cs-earlier-role {
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .cs-earlier-dates {
    margin-left: auto;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }

  .cs-earlier-note {
    margin: 0.3rem 0 0;
    font-size: 0.93rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  /* --- Two-up (leadership / education) ---------------------------------- */
  .cs-two-up {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.5rem;
  }

  .cs-plain-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .cs-plain-list li {
    font-size: 0.97rem;
    line-height: 1.58;
    color: var(--text-muted);
  }

  .cs-edu-degree {
    display: block;
    font-weight: 600;
    color: var(--text);
  }

  .cs-edu-meta {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.88rem;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
  }

  /* --- Mobile ----------------------------------------------------------- */
  @media (max-width: 700px) {
    .cs-role {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .cs-role-meta {
      border-left: 0;
      padding-left: 0;
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }

    .cs-role-meta::before {
      display: none;
    }

    .cs-role-company {
      margin-top: 0;
    }

    .cs-two-up {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .cs-earlier-dates {
      margin-left: 0;
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .cs {
      padding: 0 1.15rem;
    }
  }
</style>
