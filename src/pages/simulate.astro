---
import { profile } from "../data/profile";
import "../styles/global.css";
import ThemeScript from "../components/ThemeScript.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <title>{profile.name} — Year in 60s</title>
  </head>
  <body>
    <ThemeToggle />
    <div id="sim-root" class="sim-root">
      <div class="sim-name">{profile.name}</div>
      <div class="sim-tag">{profile.tagline}</div>

      <div class="sim-readout">
        <div class="sim-day">Day <span id="sim-day-num">1</span> / 365</div>
        <div class="sim-season">
          <span id="sim-season">Winter</span>
          <span class="arrow">→</span>
          <span id="sim-next">Spring</span>
        </div>
        <div class="sim-date" id="sim-date">Jan 1</div>
      </div>

      <div class="sim-progress">
        <div class="sim-progress-fill" id="sim-progress-fill"></div>
      </div>

      <div class="sim-controls">
        <button id="sim-play" type="button">Pause</button>
        <button id="sim-restart" type="button">Restart</button>
        <label>
          <span>Speed</span>
          <select id="sim-speed">
            <option value="30000">30s/yr (2×)</option>
            <option value="60000" selected>60s/yr (1×)</option>
            <option value="120000">120s/yr (½×)</option>
          </select>
        </label>
      </div>

      <a class="sim-back" href="/">← back to site</a>
    </div>

    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
      }

      .sim-root {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.2rem;
        padding: 2rem;
        transition: background 0.1s linear;
      }

      .sim-name {
        font-size: clamp(2.4rem, 6vw, 4rem);
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .sim-tag {
        font-size: 1.2rem;
        color: var(--text-subtle);
        margin-bottom: 2rem;
      }

      .sim-readout {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        font-variant-numeric: tabular-nums;
        font-size: 1.1rem;
        color: var(--text-muted);
      }

      .sim-day {
        font-weight: 500;
      }

      .sim-season {
        color: var(--text-subtle);
      }

      .arrow {
        margin: 0 0.3em;
        opacity: 0.5;
      }

      .sim-date {
        color: var(--text-subtle);
      }

      .sim-progress {
        width: min(600px, 80vw);
        height: 6px;
        background: var(--surface);
        border-radius: 3px;
        overflow: hidden;
      }

      .sim-progress-fill {
        height: 100%;
        width: 0;
        background: linear-gradient(
          90deg,
          #a8c5e8,
          #8ec28e,
          #d4b95e,
          #d68c45,
          #a8c5e8
        );
        transition: width 0.1s linear;
      }

      .sim-controls {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-top: 0.5rem;
      }

      .sim-controls button {
        padding: 0.5rem 1.2rem;
        border: 1px solid var(--border-strong);
        background: var(--glass);
        border-radius: 999px;
        font-size: 0.95rem;
        cursor: pointer;
        font-family: inherit;
        color: inherit;
        transition: all 0.2s ease;
      }

      .sim-controls button:hover {
        background: var(--accent-tint);
        border-color: var(--accent-tint-border);
      }

      .sim-controls label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: var(--text-subtle);
      }

      .sim-controls select {
        padding: 0.4rem 0.6rem;
        border: 1px solid var(--border-strong);
        background: var(--glass);
        color: inherit;
        border-radius: 6px;
        font-family: inherit;
        font-size: 0.9rem;
        cursor: pointer;
      }

      .sim-back {
        position: fixed;
        top: 1.5rem;
        left: 1.5rem;
        color: var(--text-subtle);
        text-decoration: none;
        font-size: 0.9rem;
      }

      .sim-back:hover {
        color: var(--accent);
      }
    </style>

    <script>
      import { getSeasonalColorsForDay } from "../utils/seasonalGradient.js";

      const root = document.getElementById("sim-root")!;
      const dayNumEl = document.getElementById("sim-day-num")!;
      const seasonEl = document.getElementById("sim-season")!;
      const nextEl = document.getElementById("sim-next")!;
      const dateEl = document.getElementById("sim-date")!;
      const fillEl = document.getElementById("sim-progress-fill")!;
      const playBtn = document.getElementById("sim-play") as HTMLButtonElement;
      const restartBtn = document.getElementById(
        "sim-restart",
      ) as HTMLButtonElement;
      const speedSel = document.getElementById(
        "sim-speed",
      ) as HTMLSelectElement;

      const MONTH_NAMES = [
        "Jan",
        "Feb",
        "Mar",
        "Apr",
        "May",
        "Jun",
        "Jul",
        "Aug",
        "Sep",
        "Oct",
        "Nov",
        "Dec",
      ];

      function dayOfYearToDate(day: number): string {
        const d = new Date(2025, 0, day);
        return `${MONTH_NAMES[d.getMonth()]} ${d.getDate()}`;
      }

      let durationMs = parseInt(speedSel.value, 10);
      let startTime = performance.now();
      let pausedAt: number | null = null;
      let rafId = 0;

      function applyDay(day: number) {
        const isDark = document.documentElement.dataset.theme === "dark";
        const { startColor, endColor, seasonLabel, nextSeasonLabel } =
          getSeasonalColorsForDay(day, isDark);
        root.style.background = `linear-gradient(135deg, ${startColor} 0%, ${endColor} 100%)`;
        dayNumEl.textContent = String(Math.max(1, Math.round(day)));
        seasonEl.textContent = seasonLabel;
        nextEl.textContent = nextSeasonLabel;
        dateEl.textContent = dayOfYearToDate(Math.max(1, Math.round(day)));
        fillEl.style.width = `${(day / 365) * 100}%`;
      }

      function tick(now: number) {
        const elapsed = (now - startTime) % durationMs;
        const day = (elapsed / durationMs) * 365;
        applyDay(day);
        rafId = requestAnimationFrame(tick);
      }

      function play() {
        if (pausedAt !== null) {
          startTime += performance.now() - pausedAt;
          pausedAt = null;
        } else {
          startTime = performance.now();
        }
        playBtn.textContent = "Pause";
        rafId = requestAnimationFrame(tick);
      }

      function pause() {
        cancelAnimationFrame(rafId);
        pausedAt = performance.now();
        playBtn.textContent = "Play";
      }

      playBtn.addEventListener("click", () => {
        if (pausedAt === null) pause();
        else play();
      });

      restartBtn.addEventListener("click", () => {
        cancelAnimationFrame(rafId);
        pausedAt = null;
        startTime = performance.now();
        playBtn.textContent = "Pause";
        rafId = requestAnimationFrame(tick);
      });

      speedSel.addEventListener("change", () => {
        const wasPaused = pausedAt !== null;
        durationMs = parseInt(speedSel.value, 10);
        startTime = performance.now();
        pausedAt = wasPaused ? performance.now() : null;
        if (!wasPaused) {
          cancelAnimationFrame(rafId);
          rafId = requestAnimationFrame(tick);
        }
      });

      play();
    </script>
  </body>
</html>
