---
import VariantBase from "../../layouts/VariantBase.astro";
import EditorialNav from "../../components/EditorialNav.astro";
import { profile } from "../../data/profile";
---

<VariantBase
  title={`${profile.name} — ${profile.title} · SF`}
  description={profile.hook}
  variant="editorial"
  page=""
>
  <article class="editorial">
    <EditorialNav page="" />

    <section class="hero">
      <p class="kicker">{profile.tagline}</p>
      <h1>{profile.hook}</h1>
      <p class="byline">
        {profile.name} · {profile.title} · {profile.locationShort}
      </p>
    </section>

    <hr class="rule" />

    <section class="pillars" aria-label="What I work on">
      {
        profile.pillars.map((p, i) => (
          <div class="pillar">
            <span class="pillar-num">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h2>{p.label}</h2>
              <p>{p.blurb}</p>
            </div>
          </div>
        ))
      }
    </section>

    <ul class="highlights" aria-label="Highlights">
      {profile.highlights.map((h) => <li>{h}</li>)}
    </ul>

    <hr class="rule" />

    <section class="summary" aria-label="Summary">
      {
        profile.summary.map((para, i) => (
          <p class:list={["body-para", { lead: i === 0 }]}>{para}</p>
        ))
      }
    </section>

    <section class="looking">
      <h3>What I'm looking for</h3>
      <p>{profile.lookingFor}</p>
    </section>

    <hr class="rule" />

    <footer class="colophon">
      <p class="contact">
        <a href={`mailto:${profile.email}`}>Email</a>
        <span class="dot">·</span>
        <a href={profile.resumeHref}>Résumé</a>
        <span class="dot">·</span>
        <a href={profile.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <span class="dot">·</span>
        <a href={profile.github} target="_blank" rel="noopener">GitHub</a>
      </p>
      <p class="source">
        Typeset by hand. <a
          href={profile.sourceUrl}
          target="_blank"
          rel="noopener">View the source</a
        >.
      </p>
    </footer>
  </article>
</VariantBase>

<style>
  /* The universal `* { font-family: system-ui }` in global.css re-sets the
     font on every element, so serif must be declared directly on the text
     elements rather than relying on cascade from a container. */
  .editorial {
    max-width: 64ch;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .editorial :is(h1, h2, h3, p, li, blockquote) {
    font-family: Georgia, "Iowan Old Style", "Times New Roman", ui-serif, serif;
  }

  /* --- Hero ------------------------------------------------------------- */
  .hero {
    padding: 1.5rem 0 0.5rem;
  }

  .kicker {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(1.9rem, 5vw, 2.9rem);
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text);
    text-wrap: balance;
  }

  .byline {
    margin-top: 1.5rem;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text-muted);
  }

  /* --- Rules ------------------------------------------------------------ */
  .rule {
    border: 0;
    height: 1px;
    background: var(--border);
    margin: 3rem 0;
  }

  /* --- Pillars ---------------------------------------------------------- */
  .pillars {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .pillar {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: baseline;
  }

  .pillar-num {
    font-family: Georgia, "Iowan Old Style", "Times New Roman", ui-serif, serif;
    font-size: 1rem;
    font-style: italic;
    color: var(--accent);
    padding-top: 0.2rem;
  }

  .pillar h2 {
    font-size: 1.3rem;
    font-weight: 400;
    margin-bottom: 0.4rem;
    color: var(--text);
  }

  .pillar p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* --- Highlights ------------------------------------------------------- */
  .highlights {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .highlights li {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--surface-border);
    border-radius: 999px;
    background: var(--surface);
  }

  /* --- Summary ---------------------------------------------------------- */
  .summary {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .body-para {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--text);
  }

  .body-para.lead {
    font-size: 1.3rem;
    line-height: 1.65;
  }

  /* Drop cap on the lead paragraph — a quiet editorial flourish. */
  .body-para.lead::first-letter {
    font-size: 3.1rem;
    line-height: 0.85;
    float: left;
    padding: 0.1rem 0.5rem 0 0;
    color: var(--accent);
    font-weight: 400;
  }

  /* --- Looking for ------------------------------------------------------ */
  .looking {
    margin-top: 2.5rem;
    padding-left: 1.25rem;
    border-left: 2px solid var(--accent-tint-border);
  }

  .looking h3 {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 0.6rem;
  }

  .looking p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text);
    font-style: italic;
  }

  /* --- Colophon --------------------------------------------------------- */
  .colophon {
    text-align: center;
  }

  .contact {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }

  .contact a {
    color: var(--link);
    transition: color 0.2s ease;
  }

  .contact a:hover {
    color: var(--accent);
  }

  .dot {
    color: var(--text-faint);
    margin: 0 0.6rem;
  }

  .source {
    margin-top: 1rem;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text-subtle);
  }

  .source a {
    color: var(--link);
    border-bottom: 1px solid var(--border);
  }

  .source a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 480px) {
    .editorial {
      padding: 0 1.1rem;
    }
    .pillar {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .pillar-num {
      padding-top: 0;
    }
    .body-para.lead::first-letter {
      font-size: 2.6rem;
    }
  }
</style>
