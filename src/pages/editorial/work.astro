---
import VariantBase from "../../layouts/VariantBase.astro";
import EditorialNav from "../../components/EditorialNav.astro";
import { profile } from "../../data/profile";
import {
  experience,
  earlier,
  leadership,
  education,
} from "../../data/experience";
---

<VariantBase
  title={`Work — ${profile.name}`}
  description={`Experience and roles — ${profile.name}, ${profile.title}.`}
  variant="editorial"
  page="work"
>
  <article class="editorial">
    <EditorialNav page="work" />

    <header class="page-head">
      <p class="kicker">Curriculum Vitæ</p>
      <h1>Work</h1>
      <p class="subtitle">
        A backend engineer's record — the systems, the incidents, and the
        platform around them.
      </p>
    </header>

    <hr class="rule" />

    <section aria-label="Experience">
      {
        experience.map((role) => (
          <article class="role">
            <header class="role-head">
              <h2>{role.title}</h2>
              <p class="role-meta">
                <span class="company">{role.company}</span>
                <span class="dates">{role.dates}</span>
              </p>
              {role.context && <p class="context">{role.context}</p>}
            </header>
            <ul class="bullets">
              {role.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>

    <hr class="rule" />

    <section class="earlier" aria-label="Earlier roles">
      <h3 class="section-label">Earlier</h3>
      <dl>
        {
          earlier.map((r) => (
            <div class="earlier-row">
              <dt>
                {r.title}, {r.company}
                <span class="earlier-dates">{r.dates}</span>
              </dt>
              <dd>{r.note}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="two-up">
      <div>
        <h3 class="section-label">Leadership</h3>
        <ul class="plain">
          {leadership.map((l) => <li>{l}</li>)}
        </ul>
      </div>
      <div>
        <h3 class="section-label">Education</h3>
        <ul class="plain">
          {
            education.map((e) => (
              <li>
                <strong>{e.degree}</strong>
                <br />
                {e.school} · {e.dates}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <hr class="rule" />

    <footer class="page-foot">
      <a href={profile.resumeHref}>Read the full résumé (PDF)</a>
    </footer>
  </article>
</VariantBase>

<style>
  .editorial {
    max-width: 64ch;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .editorial :is(h1, h2, h3, p, li, dt, dd, blockquote) {
    font-family: Georgia, "Iowan Old Style", "Times New Roman", ui-serif, serif;
  }

  /* --- Page head -------------------------------------------------------- */
  .page-head {
    padding: 1.5rem 0 0;
  }

  .kicker,
  .section-label {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .subtitle {
    margin-top: 1rem;
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--text-muted);
    text-wrap: balance;
  }

  .rule {
    border: 0;
    height: 1px;
    background: var(--border);
    margin: 2.75rem 0;
  }

  /* --- Roles ------------------------------------------------------------ */
  .role {
    margin-bottom: 2.75rem;
  }

  .role:last-child {
    margin-bottom: 0;
  }

  .role-head h2 {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
  }

  .role-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }

  .company {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text);
  }

  .dates {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    color: var(--text-subtle);
    white-space: nowrap;
  }

  .context {
    margin-top: 0.5rem;
    font-size: 1rem;
    font-style: italic;
    color: var(--text-subtle);
  }

  .bullets {
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .bullets li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--text);
  }

  .bullets li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* --- Earlier ---------------------------------------------------------- */
  .earlier dl {
    margin: 0;
  }

  .earlier-row {
    padding: 0.9rem 0;
    border-top: 1px solid var(--border);
  }

  .earlier-row:first-child {
    border-top: 0;
  }

  .earlier dt {
    font-size: 1.05rem;
    color: var(--text);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: baseline;
  }

  .earlier-dates {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.8rem;
    color: var(--text-subtle);
  }

  .earlier dd {
    margin: 0.3rem 0 0;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  /* --- Two-up (leadership / education) ---------------------------------- */
  .two-up {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin-top: 2.75rem;
  }

  .plain {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .plain li {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text);
  }

  .plain strong {
    font-weight: 600;
  }

  /* --- Footer ----------------------------------------------------------- */
  .page-foot {
    text-align: center;
  }

  .page-foot a {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--link);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.1rem;
    transition: border-color 0.2s ease;
  }

  .page-foot a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 560px) {
    .two-up {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .editorial {
      padding: 0 1.1rem;
    }
  }
</style>
