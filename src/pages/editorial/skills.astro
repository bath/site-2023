---
import VariantBase from "../../layouts/VariantBase.astro";
import EditorialNav from "../../components/EditorialNav.astro";
import { profile } from "../../data/profile";
import { skillGroups, topSkills } from "../../data/skills";
---

<VariantBase
  title={`Skills — ${profile.name}`}
  description={`What I work with — ${profile.name}, ${profile.title}.`}
  variant="editorial"
  page="skills"
>
  <article class="editorial">
    <EditorialNav page="skills" />

    <header class="page-head">
      <p class="kicker">The Toolkit</p>
      <h1>Skills</h1>
    </header>

    <section class="top" aria-label="Core strengths">
      {topSkills.map((s) => <p class="top-line">{s}</p>)}
    </section>

    <hr class="rule" />

    <section class="groups" aria-label="Skill groups">
      {
        skillGroups.map((g) => (
          <div class="group">
            <h2 class="group-label">{g.label}</h2>
            <p class="group-items">
              {g.items.map((item, i) => (
                <>
                  {i > 0 && <span class="sep"> · </span>}
                  <span class="item">{item}</span>
                </>
              ))}
            </p>
          </div>
        ))
      }
    </section>

    <hr class="rule" />

    <footer class="page-foot">
      <p>
        <a href="/editorial/work">See how these show up in the work →</a>
      </p>
    </footer>
  </article>
</VariantBase>

<style>
  .editorial {
    max-width: 64ch;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .editorial :is(h1, h2, h3, p, li, blockquote) {
    font-family: Georgia, "Iowan Old Style", "Times New Roman", ui-serif, serif;
  }

  .page-head {
    padding: 1.5rem 0 1.5rem;
  }

  .kicker {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  /* --- Top strengths — set as a lead statement -------------------------- */
  .top {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .top-line {
    font-size: clamp(1.3rem, 3.5vw, 1.7rem);
    line-height: 1.35;
    font-weight: 400;
    color: var(--text);
    text-wrap: balance;
  }

  .top-line::before {
    content: "—  ";
    color: var(--accent);
  }

  .rule {
    border: 0;
    height: 1px;
    background: var(--border);
    margin: 2.75rem 0;
  }

  /* --- Groups — label / inline run, like an index ----------------------- */
  .groups {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .group {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
  }

  .group-label {
    font-family:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-subtle);
    font-weight: 600;
    padding-top: 0.2rem;
  }

  .group-items {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text);
  }

  .sep {
    color: var(--text-faint);
  }

  /* --- Footer ----------------------------------------------------------- */
  .page-foot {
    text-align: center;
  }

  .page-foot a {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--link);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.1rem;
    transition: border-color 0.2s ease;
  }

  .page-foot a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 560px) {
    .group {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .group-label {
      padding-top: 0;
    }
  }

  @media (max-width: 480px) {
    .editorial {
      padding: 0 1.1rem;
    }
  }
</style>
