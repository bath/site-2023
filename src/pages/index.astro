---
import MainLayout from "../layouts/MainLayout.astro";
import { profile } from "../data/profile";
---

<MainLayout>
  <div class="page-content about">
    <p class="greeting">
      <span class="greeting-text" data-live="greeting-text">Hello</span>
      <span class="greeting-emoji" aria-hidden="true" data-live="greeting-emoji"
        >👋🏻</span
      >
      <span class="greeting-sep">— I'm Miller.</span>
    </p>

    {profile.summary.map((paragraph) => <p>{paragraph}</p>)}

    <p class="cta">
      Reach me at <a href={`mailto:${profile.email}`}>{profile.email}</a>, or
      find me on <a href={profile.linkedin}>LinkedIn</a> and <a
        href={profile.github}>GitHub</a>.
    </p>
  </div>
</MainLayout>

<style>
  .about {
    max-width: 62ch;
  }

  .about p {
    margin-bottom: 1.2em;
    font-size: 1.1em;
  }

  .greeting {
    font-size: 1.3em !important;
    margin-bottom: 1.8em !important;
  }

  .greeting-text {
    font-weight: 500;
  }

  .greeting-emoji {
    display: inline-block;
    margin: 0 0.25em;
  }

  .greeting-sep {
    color: rgba(35, 31, 32, 0.75);
  }

  .cta {
    margin-top: 2em !important;
    padding-top: 1.2em;
    border-top: 1px solid rgba(35, 31, 32, 0.15);
    font-size: 1em !important;
    color: rgba(35, 31, 32, 0.8);
  }
</style>
