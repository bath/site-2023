---
import MainLayout from "../layouts/MainLayout.astro";
import { profile } from "../data/profile";
---

<MainLayout>
  <div class="page-content about">
    <p class="greeting">
      <span class="greeting-text" data-live="greeting-text">Hello</span>
      <span class="greeting-emoji" aria-hidden="true" data-live="greeting-emoji"
        >👋🏻</span
      >
      <span class="greeting-sep">— I'm Miller.</span>
    </p>

    <p class="hook">{profile.hook}</p>

    <ul class="highlights" aria-label="Highlights">
      {profile.highlights.map((h) => <li>{h}</li>)}
    </ul>

    {profile.summary.map((paragraph) => <p>{paragraph}</p>)}

    <p class="looking">{profile.lookingFor}</p>

    <p class="cta">
      Reach me at <a href={`mailto:${profile.email}`}>{profile.email}</a> · <a
        href={profile.resumeHref}>Résumé</a
      > · <a href={profile.linkedin}>LinkedIn</a> · <a href={profile.github}
        >GitHub</a
      >
    </p>

    <p class="colophon">
      Built with Astro — <a href={profile.sourceUrl}>this site is open source</a
      >.
    </p>
  </div>
</MainLayout>

<style>
  .about {
    max-width: 60ch;
  }

  .about p {
    margin-bottom: 1.2em;
    font-size: 1.1em;
  }

  .greeting {
    font-size: 1.3em;
    margin-bottom: 1.1em;
  }

  .greeting-text {
    font-weight: 500;
  }

  .greeting-emoji {
    display: inline-block;
    margin: 0 0.25em;
  }

  .greeting-sep {
    color: var(--text-muted);
  }

  .about .hook {
    font-size: 1.5em;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 0.7em;
    color: var(--text);
  }

  .highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 2.1em;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
  }

  .highlights li {
    font-size: 0.9em;
    font-weight: 500;
    padding: 0.35em 0.85em;
    border-radius: 999px;
    background: var(--accent-tint);
    border: 1px solid var(--accent-tint-border);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .about .looking {
    margin-top: 2em;
    padding: 0.85em 1.1em;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 8px 8px 0;
    font-size: 1.02em;
    color: var(--text-muted);
  }

  .about .cta {
    margin-top: 2em;
    padding-top: 1.2em;
    border-top: 1px solid var(--border);
    font-size: 1em;
    color: var(--text-muted);
  }

  .about .cta a {
    color: var(--link);
    font-weight: 500;
  }

  /* internal links (résumé pdf) don't match the global http/mailto underline */
  .about .cta a:not([href^="http"]):not([href^="mailto"]) {
    border-bottom: 1px solid transparent;
  }

  .about .cta a:not([href^="http"]):not([href^="mailto"]):hover {
    border-bottom-color: currentColor;
  }

  .about .colophon {
    margin-top: 0.7em;
    font-size: 0.88em;
    color: var(--text-faint);
  }

  .about .colophon a {
    color: var(--text-subtle);
  }

  @media (max-width: 820px) {
    .about .hook {
      font-size: 1.3em;
    }
  }
</style>
