---
import VariantBase from "../layouts/VariantBase.astro";
import { profile } from "../data/profile";

const directions = [
  {
    key: "editorial",
    name: "Editorial Prose",
    desc: "Single centered column, large serif display, generous whitespace. Reads like a beautifully typeset essay.",
  },
  {
    key: "sidebar",
    name: "Refined Sidebar",
    desc: "A polished evolution of the current fixed-sidebar layout — sharper type scale, spacing, and motion.",
  },
  {
    key: "hero",
    name: "Warm Gradient Hero",
    desc: "The day-of-year gradient and live time/day become a hero band, with a clean single-column body below.",
  },
  {
    key: "casestudy",
    name: "Case-Study Portfolio",
    desc: "Work and projects are the spine — an evidence-led timeline leading with Payment Plans and the AI-tooling fleet work.",
  },
];
---

<VariantBase
  title={`${profile.name} — choose a design`}
  description="Preview the four candidate designs for the site revamp."
  showSwitcher={false}
>
  <main class="hub">
    <header class="hub-head">
      <p class="hub-eyebrow">Site revamp · preview</p>
      <h1>Four directions</h1>
      <p class="hub-sub">
        Same content — backend engineering + AI tooling — in four layouts and
        looks. Open each, toggle light/dark (top-right), and pick the one you
        like. Use the bar at the bottom of any preview to hop between them.
      </p>
    </header>

    <ul class="hub-grid">
      {
        directions.map((d, i) => (
          <li>
            <a class="card" href={`/${d.key}`}>
              <span class="card-index">{String(i + 1).padStart(2, "0")}</span>
              <span class="card-name">{d.name}</span>
              <span class="card-desc">{d.desc}</span>
              <span class="card-go">View →</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</VariantBase>

<style>
  .hub {
    max-width: 860px;
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 6rem) 1.5rem 3rem;
  }

  .hub-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: var(--accent-strong);
    margin-bottom: 0.6rem;
  }

  .hub h1 {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    line-height: 1.05;
    margin-bottom: 0.7rem;
  }

  .hub-sub {
    color: var(--text-muted);
    max-width: 56ch;
    line-height: 1.55;
    font-size: 1.05rem;
  }

  .hub-grid {
    list-style: none;
    margin: 2.6rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    height: 100%;
    padding: 1.4rem 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--surface-border);
    background: var(--surface);
    color: var(--text);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-tint-border);
    background: var(--accent-tint);
  }

  .card-index {
    font-variant-numeric: tabular-nums;
    font-size: 0.8rem;
    color: var(--text-faint);
    letter-spacing: 0.1em;
  }

  .card-name {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .card-desc {
    color: var(--text-muted);
    line-height: 1.5;
    font-size: 0.95rem;
    flex: 1;
  }

  .card-go {
    margin-top: 0.4rem;
    font-weight: 600;
    color: var(--link);
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
