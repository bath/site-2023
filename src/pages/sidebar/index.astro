---
import VariantBase from "../../layouts/VariantBase.astro";
import SidebarNav from "../../components/SidebarNav.astro";
import CompanyText from "../../components/CompanyText.astro";
import { profile } from "../../data/profile";
---

<VariantBase
  title={`${profile.name} — ${profile.title} · SF`}
  description={profile.hook}
  variant="sidebar"
  page=""
>
  <SidebarNav page="" />

  <main class="sb-content">
    <div class="sb-page">
      <p class="sb-greeting">
        <span class="sb-wave" aria-hidden="true">👋🏻</span>
        Hi — I'm {profile.name}.
      </p>

      <h1 class="sb-hook">{profile.hook}</h1>

      <ul class="sb-highlights" aria-label="Highlights">
        {profile.highlights.map((h) => <li>{h}</li>)}
      </ul>

      <section class="sb-pillars" aria-label="What I do">
        {
          profile.pillars.map((p) => (
            <article class="sb-pillar">
              <h2 class="sb-pillar-label">{p.label}</h2>
              <p class="sb-pillar-blurb">{p.blurb}</p>
            </article>
          ))
        }
      </section>

      <div class="sb-summary">
        {
          profile.summary.map((paragraph) => (
            <p>
              <CompanyText text={paragraph} />
            </p>
          ))
        }
      </div>

      <p class="sb-looking">{profile.lookingFor}</p>

      <p class="sb-contact">
        Reach me at <a href={`mailto:${profile.email}`}>{profile.email}</a> · <a
          href={profile.resumeHref}>Résumé</a
        > · <a href={profile.linkedin}>LinkedIn</a> · <a href={profile.github}
          >GitHub</a
        >
      </p>

      <p class="sb-colophon">
        Built with <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer">Astro</a
        > — <a href={profile.sourceUrl}>this site is open source</a>.
      </p>
    </div>
  </main>
</VariantBase>

<style>
  /* Content sits to the right of the 300px fixed rail on desktop, full-width
     on mobile (rail collapses to a top bar — see SidebarNav). */
  .sb-content {
    margin-left: 300px;
    padding: 4.5rem 4rem 4rem;
    min-height: 100vh;
    line-height: 1.6;
  }

  .sb-page {
    max-width: 60ch;
    animation: sbFadeIn 0.45s ease-out;
  }

  .sb-greeting {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin: 0 0 0.9rem;
  }

  .sb-wave {
    display: inline-block;
    margin-right: 0.2rem;
  }

  .sb-hook {
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .sb-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sb-highlights li {
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.35em 0.85em;
    border-radius: 999px;
    background: var(--accent-tint);
    border: 1px solid var(--accent-tint-border);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .sb-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .sb-pillar {
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--surface-border);
    background: var(--surface);
    border-radius: 12px;
  }

  .sb-pillar-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.45rem;
    color: var(--text);
  }

  .sb-pillar-blurb {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0;
  }

  .sb-summary p {
    font-size: 1.05rem;
    margin: 0 0 1.2rem;
  }

  /* company links inside the summary keep text color with a subtle underline */
  .sb-summary :global(a.company-link) {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--text-faint);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s ease;
  }

  .sb-summary :global(a.company-link:hover) {
    text-decoration-color: var(--accent);
  }

  .sb-looking {
    margin: 2rem 0 0;
    padding: 0.9em 1.1em;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 8px 8px 0;
    font-size: 1.02rem;
    color: var(--text-muted);
  }

  .sb-contact {
    margin: 2rem 0 0;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    font-size: 0.98rem;
    color: var(--text-muted);
  }

  .sb-contact a,
  .sb-colophon a {
    color: var(--link);
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .sb-contact a:hover,
  .sb-colophon a:hover {
    border-bottom-color: currentColor;
  }

  .sb-colophon {
    margin: 0.7rem 0 0;
    font-size: 0.85rem;
    color: var(--text-faint);
  }

  .sb-colophon a {
    color: var(--text-subtle);
    font-weight: 400;
  }

  @keyframes sbFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-page {
      animation: none;
    }
  }

  @media (max-width: 820px) {
    .sb-content {
      margin-left: 0;
      padding: 1.75rem 1.25rem 2.5rem;
      min-height: 0;
    }

    .sb-hook {
      font-size: 1.55rem;
    }

    .sb-pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
