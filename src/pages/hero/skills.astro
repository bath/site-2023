---
import VariantBase from "../../layouts/VariantBase.astro";
import LiveClock from "../../components/LiveClock.astro";
import HeroBand from "../../components/HeroBand.astro";
import { profile } from "../../data/profile";
import { skillGroups, topSkills } from "../../data/skills";
---

<VariantBase
  title={`Skills — ${profile.name}`}
  description="Skills: backend & API design, applied-AI tooling, distributed systems."
  variant="hero"
  page="skills"
>
  <main class="hero-page">
    <HeroBand size="slim" page="skills" />

    <div class="body">
      <section class="top" aria-label="Core strengths">
        <span class="eyebrow">Core strengths</span>
        <ul class="top-list">
          {topSkills.map((s) => <li class="top-item">{s}</li>)}
        </ul>
      </section>

      <section class="groups" aria-label="Skills by area">
        {
          skillGroups.map((g) => (
            <article class="group">
              <h2 class="group-label">{g.label}</h2>
              <ul class="group-items">
                {g.items.map((item) => (
                  <li class="group-chip">{item}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </section>
    </div>
  </main>
</VariantBase>
<LiveClock />

<style>
  .hero-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.25rem 1.25rem 2rem;
  }

  .body {
    margin-top: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 2.6rem;
    line-height: 1.6;
  }

  .eyebrow {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }

  /* ---- top skills ---- */
  .top-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .top-item {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    padding-left: 1rem;
    border-left: 3px solid var(--accent);
  }

  /* ---- skill groups ---- */
  .groups {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .group {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr);
    gap: 0.5rem 1.25rem;
    align-items: baseline;
  }

  .group-label {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-subtle);
    font-weight: 700;
  }

  .group-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .group-chip {
    font-size: 0.88rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
  }

  @media (max-width: 560px) {
    .group {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .top-item {
      font-size: 1.1rem;
    }
  }
</style>
