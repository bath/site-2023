---
import VariantBase from "../../layouts/VariantBase.astro";
import LiveClock from "../../components/LiveClock.astro";
import HeroBand from "../../components/HeroBand.astro";
import { profile } from "../../data/profile";
import {
  experience,
  earlier,
  leadership,
  education,
} from "../../data/experience";
---

<VariantBase
  title={`Work — ${profile.name}`}
  description="Experience: payments platform engineering and applied-AI tooling."
  variant="hero"
  page="work"
>
  <main class="hero-page">
    <HeroBand size="slim" page="work" />

    <div class="body">
      <section class="roles" aria-label="Experience">
        {
          experience.map((role) => (
            <article class="role">
              <header class="role-head">
                <h2 class="role-title">
                  {role.title} <span class="role-company">· {role.company}</span>
                </h2>
                <span class="role-dates">{role.dates}</span>
              </header>
              {role.context && <p class="role-context">{role.context}</p>}
              <ul class="role-bullets">
                {role.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="block" aria-label="Earlier">
        <h2 class="block-head">Earlier</h2>
        <ul class="earlier">
          {
            earlier.map((e) => (
              <li>
                <span class="earlier-role">{e.title}</span>
                <span class="earlier-company"> · {e.company}</span>
                <span class="earlier-dates"> · {e.dates}</span>
                <p class="earlier-note">{e.note}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="block" aria-label="Leadership">
        <h2 class="block-head">Leadership</h2>
        <ul class="plain-list">
          {leadership.map((l) => <li>{l}</li>)}
        </ul>
      </section>

      <section class="block" aria-label="Education">
        <h2 class="block-head">Education</h2>
        <ul class="plain-list">
          {
            education.map((ed) => (
              <li>
                {ed.degree}, {ed.school} · {ed.dates}
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
</VariantBase>
<LiveClock />

<style>
  .hero-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.25rem 1.25rem 2rem;
  }

  .body {
    margin-top: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 2.6rem;
    line-height: 1.6;
  }

  /* ---- roles ---- */
  .roles {
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }

  .role-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.2rem 1rem;
  }

  .role-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  .role-company {
    color: var(--accent-strong);
    font-weight: 600;
  }

  .role-dates {
    font-size: 0.85rem;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .role-context {
    margin: 0.35rem 0 0.9rem;
    font-size: 0.92rem;
    color: var(--text-subtle);
    font-style: italic;
  }

  .role-bullets {
    margin: 0;
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .role-bullets li {
    font-size: 0.97rem;
    color: var(--text-muted);
    padding-left: 0.2rem;
  }

  .role-bullets li::marker {
    color: var(--accent);
  }

  /* ---- shared block sections ---- */
  .block-head {
    margin: 0 0 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
  }

  .earlier {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .earlier-role {
    font-weight: 700;
    color: var(--text);
  }

  .earlier-company {
    color: var(--text-muted);
  }

  .earlier-dates {
    color: var(--text-subtle);
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  .earlier-note {
    margin: 0.25rem 0 0;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .plain-list {
    margin: 0;
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .plain-list li {
    font-size: 0.97rem;
    color: var(--text-muted);
  }

  .plain-list li::marker {
    color: var(--accent);
  }

  @media (max-width: 560px) {
    .body {
      gap: 2.2rem;
    }
    .role-dates {
      width: 100%;
    }
  }
</style>
